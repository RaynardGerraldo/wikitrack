{
  "manifest_version": 3,
  "name": "Wikitrack",
  "version": "0.2.0",
  "description": "Track Wikipedia reading progress by article and section.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.wikipedia.org/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "jmjw@wikitrack",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.wikipedia.org/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wikitrack reading list"
  }
}
